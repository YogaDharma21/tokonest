meta {
  name: Get Shipping
  type: http
  seq: 4
}

get {
  url: {{app_url}}/api/cart/shipping?courier=tiki
  body: multipartForm
  auth: inherit
}

params:query {
  courier: tiki
}

headers {
  Accept: application/json
  Authorization: Bearer {{sanctum_token}}
}

body:multipart-form {
  ~courier: jne
}
