meta {
  name: Profile
  type: http
  seq: 3
}

get {
  url: {{app_url}}/api/profile
  body: multipartForm
  auth: inherit
}

headers {
  Accept: application/json
  Authorization: Bearer {{token}}
}

body:multipart-form {
  phone_email: contoh@contoh.contoh
  password: 123456
}

settings {
  encodeUrl: true
}
