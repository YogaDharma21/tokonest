meta {
  name: Check OTP Forgot Password
  type: http
  seq: 2
}

post {
  url: {{app_url}}/api/forgot-password/check-otp
  body: multipartForm
  auth: inherit
}

headers {
  Accept: application/json
}

body:multipart-form {
  email: contoh@contoh.contoh
  otp: 829930
}

settings {
  encodeUrl: true
  timeout: 0
}
