meta {
  name: Create Withdraw
  type: http
  seq: 3
}

post {
  url: {{app_url}}/api/seller-dashboard/withdraw
  body: multipartForm
  auth: inherit
}

headers {
  Accept: application/json
  Authorization: Bearer {{sanctum_token}}
}

body:multipart-form {
  amount: 5000
  description: Beli laptop baru
  bank_code: 008
  bank_account_number: 3424242213213
  bank_account_holder: Yoga Dharma
}

settings {
  encodeUrl: true
  timeout: inherit
  followRedirects: true
  maxRedirects: 5
}
